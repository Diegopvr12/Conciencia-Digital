 <script>
 function showSection(sectionId) {
 const sections = document.querySelectorAll('.section');
 sections.forEach(s => s.classList.remove('active'));
 document.getElementById(sectionId).classList.add('active');
 
 const buttons = document.querySelectorAll('.nav-btn');
 buttons.forEach(btn => btn.classList.remove('active'));
 event.target.classList.add('active');
 
 window.scrollTo(0, 0);
 }
 
 function calculateTest() {
 const answers = [];
 for(let i = 1; i <= 6; i++) {
 const answer = document.querySelector(`input[name="q${i}"]:checked`)?.value;
 if(answer === undefined) {
 alert('Por favor responde todas las preguntas');
 return;
 }
 answers.push(parseInt(answer));
 }
 
 const total = answers.reduce((a, b) => a + b, 0);
 const percentage = (total / 18) * 100;
 
 let title, interpretation, recommendation;
 
 if(total <= 3) {
 title = '✅ BAJO - Relación Saludable';
 interpretation = 'Tu uso de redes sociales es controlado y saludable. Felicidades!';
 recommendation = 'Mantén tus hábitos actuales y sigue disfrutando de forma equilibrada.';
 } else if(total <= 8) {
 title = '⚠️ MODERADO - Requiere Atención';
 interpretation = 'Empiezas a mostrar signos de dependencia. Es buen momento para tomar acciones.';
 recommendation = 'Implementa las estrategias inmediatas: desactiva notificaciones y establece límites horarios.';
 } else if(total <= 13) {
 title = '🔴 SEVERO - Intervención Necesaria';
 interpretation = 'Tienes síntomas claros de adicción. Necesitas tomar medidas urgentes.';
 recommendation = 'Reduce tu uso drásticamente. Considera buscar ayuda profesional. Únete a nuestros retos.';
 } else {
 title = '🚨 CRÍTICO - Busca Ayuda Inmediata';
 interpretation = 'Tienes una adicción severa que requiere intervención profesional urgente.';
 recommendation = 'Contacta un psicólogo o psiquiatra especializado. Considera un digital detox radical.';
 }
 
 const resultBox = document.getElementById('resultBox');
 document.getElementById('resultTitle').textContent = title;
 document.getElementById('meterFill').style.width = percentage + '%';
 document.getElementById('meterFill').textContent = Math.round(percentage) + '%';
 document.getElementById('resultInterpretation').textContent = interpretation;
 document.getElementById('resultRecommendation').textContent = recommendation;
 
 resultBox.classList.add('show');
 resultBox.scrollIntoView({ behavior: 'smooth' });
 }
 
 function addTrackerEntry() {
 const hours = document.getElementById('hoursInput').value;
 const minutes = document.getElementById('minutesInput').value;
 
 if(!hours || hours < 0 || hours > 24 || !minutes || minutes < 0 || minutes > 59) {
 alert('Por favor ingresa valores válidos (0-24 horas, 0-59 minutos)');
 return;
 }
 
 const message = document.getElementById('todayMessage');
 message.textContent = `✅ Registrado: ${hours}h ${minutes}m`;
 message.style.display = 'block';
 
 document.getElementById('hoursInput').value = '';
 document.getElementById('minutesInput').value = '';
 }
 
 function joinChallenge(challenge) {
 alert(`¡Excelente decisión! Te has unido al reto de ${challenge}. \n\nRecibirás recordatorios diarios y actualizaciones de tu progreso. ¡Puedes lograrlo! 💪`);
 }
 
 function submitStory() {
 const story = document.getElementById('storyInput').value;
 if(story.length < 20) {
 alert('Por favor escribe una historia de al menos 20 caracteres');
 return;
 }
 
 const message = document.getElementById('storyMessage');
 message.textContent = '✅ Gracias por compartir tu historia! Inspirarás a muchas personas.';
 message.style.display = 'block';
 document.getElementById('storyInput').value = '';
 }
